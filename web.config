<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="aspNetCore"
           path="*"
           verb="*"
           modules="AspNetCoreModuleV2"
           resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath="C:\Program Files\Python312\python.exe"
                arguments="startup.py"
                stdoutLogEnabled="true"
                stdoutLogFile=".\logs\python.log"
                startupTimeLimit="60"
                processesPerApplication="1"
                hostingModel="outofprocess">
      <environmentVariables>
        <environmentVariable name="HTTP_PLATFORM_PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="AZURE_KEY_VAULT_NAME" value="goconnection-keyvault" />
      </environmentVariables>
    </aspNetCore>
  </system.webServer>
</configuration>
